{
  "name": "english-reading-ext",
  "version": "0.1.0",
  "description": "逼你用上下文猜词义的英语阅读插件 (Chrome MV3)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bx-h/English-Reading-Ext.git"
  },
  "bugs": {
    "url": "https://github.com/bx-h/English-Reading-Ext/issues"
  },
  "homepage": "https://github.com/bx-h/English-Reading-Ext#readme",
  "keywords": [
    "chrome-extension",
    "english-learning",
    "cloze",
    "reading",
    "mv3"
  ],
  "type": "module",
  "scripts": {
