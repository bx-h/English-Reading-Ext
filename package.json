    "package:dist": "pnpm build && tar -czf english-reading-ext-dist.tgz -C dist ."
  },
  "devDependencies": {
    "@crxjs/vite-plugin": "^2.0.0-beta.26",
    "@types/chrome": "^0.0.270",
    "@types/jsdom": "^28.0.3",
    "jsdom": "^29.1.1",
    "typescript": "^5.5.4",
    "vite": "^5.4.2"
  }
}
